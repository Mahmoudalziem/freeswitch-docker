# MySQL (if still used in your stack)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=asterisk
MYSQL_USER=asterisk
MYSQL_PASSWORD=asterisk

# Dongle / Asterisk
ASTERISK_DSN=asterisk-connector
ASTERISK_DB_HOST=mysql
ASTERISK_DB_NAME=asterisk
ASTERISK_DB_USER=asterisk
ASTERISK_DB_PASS=asterisk

# SIP Trunk for SMS forwarding
TRUNK_NAME=sms-trunk
TRUNK_TYPE=pjsip
TRUNK_USER=sipuser
TRUNK_PASS=sippass
TRUNK_HOST=provider.example.com
TRUNK_CONTACT=sip:${TRUNK_USER}@${TRUNK_HOST}
    
ASTERISK_VERSION=20
TZ=Africa/Cairo
